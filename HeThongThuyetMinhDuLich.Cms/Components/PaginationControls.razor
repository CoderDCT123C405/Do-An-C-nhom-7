@if (TotalItems > 0)
{
    <div class="pagination-shell">
        <div class="table-toolbar pagination-toolbar">
            <div class="pagination-meta">
                <div class="pagination-summary">Hien thi @RangeStart-@RangeEnd tren tong @TotalItems @ItemLabel</div>
                <div class="pagination-current">Trang @CurrentPage / @TotalPages</div>
            </div>
            <div class="table-toolbar-actions">
                <div class="history-page-size">
                    <label for="@_pageSizeInputId">Moi trang</label>
                    <select id="@_pageSizeInputId" value="@PageSize" @onchange="HandlePageSizeChangedAsync">
                        @foreach (var size in ResolvedPageSizeOptions)
                        {
                            <option value="@size">@size</option>
                        }
                    </select>
                </div>
                <div class="pagination-jump">
                    <label for="@_jumpInputId">Den trang</label>
                    <InputNumber id="@_jumpInputId" @bind-Value="_jumpPage" TValue="int" />
                    <button type="button" class="btn btn-secondary" @onclick="JumpToPageAsync" disabled="@(TotalPages <= 1)">Di</button>
                </div>
            </div>
        </div>

        <div class="pagination-bar">
            <div class="pagination-actions pagination-nav">
                <button type="button" class="btn btn-secondary" @onclick="(() => ChangePageAsync(1))" disabled="@(CurrentPage <= 1)">Dau</button>
                <button type="button" class="btn btn-secondary" @onclick="(() => ChangePageAsync(CurrentPage - 1))" disabled="@(CurrentPage <= 1)">Truoc</button>
                <div class="pagination-page-list">
                    @foreach (var token in BuildPageTokens())
                    {
                        if (token.IsEllipsis)
                        {
                            <span class="pagination-ellipsis">...</span>
                        }
                        else
                        {
                            <button type="button"
                                    class="btn btn-secondary pagination-page-btn @(token.Page == CurrentPage ? "active" : string.Empty)"
                                    @onclick="(() => ChangePageAsync(token.Page))">
                                @token.Page
                            </button>
                        }
                    }
                </div>
                <button type="button" class="btn btn-secondary" @onclick="(() => ChangePageAsync(CurrentPage + 1))" disabled="@(CurrentPage >= TotalPages)">Sau</button>
                <button type="button" class="btn btn-secondary" @onclick="(() => ChangePageAsync(TotalPages))" disabled="@(CurrentPage >= TotalPages)">Cuoi</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int TotalItems { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public string ItemLabel { get; set; } = "ban ghi";
    [Parameter] public IReadOnlyList<int>? PageSizeOptions { get; set; }
    [Parameter] public EventCallback<int> PageSizeChanged { get; set; }
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }

    private readonly string _pageSizeInputId = $"page-size-{Guid.NewGuid():N}";
    private readonly string _jumpInputId = $"page-jump-{Guid.NewGuid():N}";
    private int _jumpPage = 1;
    private IReadOnlyList<int> ResolvedPageSizeOptions => PageSizeOptions ?? [10, 20, 50];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalItems / (double)Math.Max(1, PageSize)));
    private int RangeStart => TotalItems == 0 ? 0 : ((CurrentPage - 1) * PageSize) + 1;
    private int RangeEnd => TotalItems == 0 ? 0 : Math.Min(CurrentPage * PageSize, TotalItems);

    protected override void OnParametersSet()
    {
        _jumpPage = Math.Clamp(CurrentPage, 1, TotalPages);
    }

    private async Task HandlePageSizeChangedAsync(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var size))
        {
            return;
        }

        if (PageSizeChanged.HasDelegate)
        {
            await PageSizeChanged.InvokeAsync(size);
        }

        if (CurrentPageChanged.HasDelegate)
        {
            await CurrentPageChanged.InvokeAsync(1);
        }
    }

    private async Task JumpToPageAsync()
        => await ChangePageAsync(_jumpPage);

    private async Task ChangePageAsync(int page)
    {
        var targetPage = Math.Clamp(page, 1, TotalPages);
        _jumpPage = targetPage;

        if (CurrentPageChanged.HasDelegate)
        {
            await CurrentPageChanged.InvokeAsync(targetPage);
        }
    }

    private IReadOnlyList<PageToken> BuildPageTokens()
    {
        if (TotalPages <= 7)
        {
            return Enumerable.Range(1, TotalPages).Select(PageToken.PageNumber).ToList();
        }

        var pages = new SortedSet<int> { 1, TotalPages, CurrentPage };
        pages.Add(Math.Max(1, CurrentPage - 1));
        pages.Add(Math.Min(TotalPages, CurrentPage + 1));

        if (CurrentPage <= 3)
        {
            pages.Add(2);
            pages.Add(3);
        }

        if (CurrentPage >= TotalPages - 2)
        {
            pages.Add(TotalPages - 1);
            pages.Add(TotalPages - 2);
        }

        var result = new List<PageToken>();
        int? previous = null;
        foreach (var page in pages.Where(x => x >= 1 && x <= TotalPages))
        {
            if (previous.HasValue && page - previous.Value > 1)
            {
                result.Add(PageToken.Ellipsis());
            }

            result.Add(PageToken.PageNumber(page));
            previous = page;
        }

        return result;
    }

    private sealed record PageToken(int Page, bool IsEllipsis)
    {
        public static PageToken PageNumber(int page) => new(page, false);
        public static PageToken Ellipsis() => new(0, true);
    }
}