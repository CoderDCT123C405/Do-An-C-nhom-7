@page "/loaidiem"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Loai diem</PageTitle>

<div class="page-title">
    <div>
        <h3>Quan ly loai diem tham quan</h3>
        <p>Tao, cap nhat va quan ly trang thai hoat dong cua loai diem.</p>
    </div>
    <button class="btn btn-secondary" @onclick="ToggleCreateForm">@(_showForm ? "Dong form" : "Them loai diem")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_success))
{
    <div class="notice notice-success">@_success</div>
}

@if (Session.IsBienTap)
{
    <div class="notice notice-success">Vai tro BienTap duoc phep tao, sua va quan ly trang thai loai diem.</div>
}

<div class="@(_showForm ? "card" : string.Empty)">
    @if (_showForm)
    {
        <div class="card">
            <h4>@(_editingId is null ? "Them loai diem" : $"Cap nhat loai diem #{_editingId}")</h4>

            <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="loai-diem-form" style="display:grid;gap:10px;margin-top:10px;">
                <DataAnnotationsValidator />

                <div>
                    <label>Ten loai</label>
                    <InputText @bind-Value="_form.TenLoai" />
                    <ValidationMessage For="() => _form.TenLoai" />
                </div>

                <div>
                    <label>Mo ta</label>
                    <InputTextArea @bind-Value="_form.MoTa" rows="3" />
                    <ValidationMessage For="() => _form.MoTa" />
                </div>

                <label style="display:flex;gap:8px;align-items:center;">
                    Trạng thái hoạt động
                    <InputCheckbox @bind-Value="_form.TrangThaiHoatDong" style=""/>
                </label>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CloseForm">Huy</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">@(_isSaving ? "Dang luu..." : "Luu")</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="card">
        @{
            var filteredItems = FilteredItems.ToList();
            var totalPages = GetTotalPages(filteredItems.Count);
            var currentPage = GetCurrentPage(filteredItems.Count);
            var pagedItems = GetPagedItems(filteredItems);
            var rangeStart = filteredItems.Count == 0 ? 0 : ((currentPage - 1) * _pageSize) + 1;
            var rangeEnd = filteredItems.Count == 0 ? 0 : Math.Min(currentPage * _pageSize, filteredItems.Count);
        }

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <h4>Danh sach loai diem</h4>
            <input placeholder="Tim theo ten loai..." style="max-width:220px;" @bind="SearchText" @bind:event="oninput" />
        </div>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ma</th>
                        <th>Ten loai</th>
                        <th>Trang thai</th>
                        <th>Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedItems)
                    {
                        <tr>
                            <td>@item.MaLoai</td>
                            <td>@item.TenLoai</td>
                            <td>
                                <span class="badge @(item.TrangThaiHoatDong ? "badge-success" : "badge-muted")">
                                    @(item.TrangThaiHoatDong ? "Hoat dong" : "Tam dung")
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:8px;">
                                    <button type="button" class="btn btn-secondary" @onclick="() => StartEdit(item)">Sua</button>
                                    <button type="button"
                                            class="btn @(item.TrangThaiHoatDong ? "btn-danger" : "btn-primary")"
                                            @onclick="() => ToggleVisibilityAsync(item)">
                                        @(item.TrangThaiHoatDong ? "An" : "Hien")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!filteredItems.Any())
                    {
                        <tr>
                            <td colspan="4">Khong co du lieu phu hop.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <PaginationControls TotalItems="@filteredItems.Count"
                            ItemLabel="loai"
                            PageSize="@_pageSize"
                            PageSizeChanged="OnPageSizeChanged"
                            CurrentPage="@currentPage"
                            CurrentPageChanged="OnPageChanged" />
    </div>
</div>

@code {
    private readonly LoaiDiemThamQuanCreate _form = new();
    private List<LoaiDiemThamQuanItem> _items = [];
    private int? _editingId;
    private bool _showForm;
    private bool _isSaving;
    private string _search = string.Empty;
    private string? _error;
    private string? _success;
    private int _page = 1;
    private int _pageSize = 10;
    private int _jumpPage = 1;

    private string SearchText
    {
        get => _search;
        set
        {
            _search = value;
            ResetPagination();
        }
    }

    private IEnumerable<LoaiDiemThamQuanItem> FilteredItems =>
        _items.Where(x => string.IsNullOrWhiteSpace(_search)
            || x.TenLoai.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _items = (await ApiClient.GetLoaiDiemAsync()).OrderBy(x => x.TenLoai).ToList();
            ResetPagination();
        }
        catch (Exception ex)
        {
            _error = "Không thể tải dữ liệu. Vui lòng thử lại sau.";
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.TenLoai = string.Empty;
        _form.MoTa = string.Empty;
        _form.TrangThaiHoatDong = true;
    }

    private void ToggleCreateForm()
    {
        if (_showForm && _editingId is null)
        {
            CloseForm();
            return;
        }

        ResetForm();
        _showForm = true;
        _error = null;
        _success = null;
    }

    private void CloseForm()
    {
        ResetForm();
        _showForm = false;
    }

    private int GetTotalPages(int totalItems)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)_pageSize));

    private int GetCurrentPage(int totalItems)
    {
        _page = Math.Clamp(_page, 1, GetTotalPages(totalItems));
        _jumpPage = _page;
        return _page;
    }

    private List<LoaiDiemThamQuanItem> GetPagedItems(IReadOnlyList<LoaiDiemThamQuanItem> items)
    {
        var currentPage = GetCurrentPage(items.Count);
        return items.Skip((currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private Task OnPageChanged(int page)
    {
        _page = page;
        _jumpPage = page;
        return Task.CompletedTask;
    }

    private Task OnPageSizeChanged(int size)
    {
        _pageSize = size;
        ResetPagination();
        return Task.CompletedTask;
    }

    private void ResetPagination()
    {
        _page = 1;
        _jumpPage = 1;
    }

    private void StartEdit(LoaiDiemThamQuanItem item)
    {
        _editingId = item.MaLoai;
        _form.TenLoai = item.TenLoai;
        _form.MoTa = item.MoTa;
        _form.TrangThaiHoatDong = item.TrangThaiHoatDong;
        _showForm = true;
        _error = null;
        _success = null;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _error = null;
        _success = null;

        try
        {
            var payload = new LoaiDiemThamQuanCreate
            {
                TenLoai = _form.TenLoai.Trim(),
                MoTa = _form.MoTa?.Trim(),
                TrangThaiHoatDong = _form.TrangThaiHoatDong
            };

            ApiOperationResult result;
            if (_editingId is null)
            {
                result = await ApiClient.CreateLoaiDiemAsync(payload);
            }
            else
            {
                result = await ApiClient.UpdateLoaiDiemAsync(_editingId.Value, payload);
            }

            if (!result.Success)
            {
                _error = CleanError(result.ErrorMessage);
                return;
            }

            _success = _editingId is null ? "Đã tạo loại điểm mới." : "Đã cập nhật loại điểm.";
            CloseForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = "Không thể lưu dữ liệu. Vui lòng thử lại sau.";
            Console.WriteLine($"Error saving data: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ToggleVisibilityAsync(LoaiDiemThamQuanItem item)
    {
        _error = null;
        _success = null;

        try
        {
            var nextStateLabel = item.TrangThaiHoatDong ? "an" : "hien";
            var confirmed = await Js.InvokeAsync<bool>("confirm", $"Ban co chac muon {nextStateLabel} loai diem '{item.TenLoai}' khong?");
            if (!confirmed)
            {
                return;
            }

            var result = await ApiClient.UpdateLoaiDiemAsync(item.MaLoai, new LoaiDiemThamQuanCreate
            {
                TenLoai = item.TenLoai,
                MoTa = item.MoTa,
                TrangThaiHoatDong = !item.TrangThaiHoatDong
            });

            if (!result.Success)
            {
                _error = CleanError(result.ErrorMessage);
                return;
            }

            _success = item.TrangThaiHoatDong
                ? $"Da an loai diem '{item.TenLoai}'."
                : $"Da hien loai diem '{item.TenLoai}'.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = "Không thể xóa dữ liệu. Vui lòng thử lại sau.";
            Console.WriteLine($"Error deleting data: {ex.Message}");
        }
    }

    private static string CleanError(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return "Co loi xay ra. Vui long thu lai.";
        }

        return raw
            .Replace("{", string.Empty)
            .Replace("}", string.Empty)
            .Replace("\"", string.Empty)
            .Trim();
    }
}
