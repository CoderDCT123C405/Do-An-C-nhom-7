@page "/maqr"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Quan ly Ma QR</PageTitle>

<div class="page-title">
    <div>
        <h3>Quan ly Ma QR</h3>
        <p>Danh sach va quan ly cac ma QR lien ket voi diem tham quan.</p>
    </div>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">@(_showForm ? "Dong form" : "Them Ma QR")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_success))
{
    <div class="notice notice-success">@_success</div>
}

<div class="card">
    @if (_showForm)
    {
        <div class="card">
            <h4>@(_editingId is null ? "Them Ma QR" : $"Cap nhat Ma QR #{_editingId}")</h4>

            <EditForm Model="_form" OnValidSubmit="SaveAsync" style="display:grid;gap:10px;margin-top:10px;">
                <DataAnnotationsValidator />

                <div>
                    <label>Ma Diem</label>
                    <InputNumber @bind-Value="_form.MaDiem" />
                    <ValidationMessage For="() => _form.MaDiem" />
                </div>

                <div>
                    <label>Gia tri QR</label>
                    <InputText @bind-Value="_form.GiaTriQR" />
                    <ValidationMessage For="() => _form.GiaTriQR" />
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CloseForm">Huy</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">@(_isSaving ? "Dang luu..." : "Luu")</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="card">
        <h4>Danh sach Ma QR</h4>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ma</th>
                        <th>Ma Diem</th>
                        <th>Gia tri QR</th>
                        <th>Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _qrItems)
                    {
                        <tr>
                            <td>@item.MaQR</td>
                            <td>@item.MaDiem</td>
                            <td>@item.GiaTriQR</td>
                            <td>
                                <div style="display:flex;gap:8px;">
                                    <button type="button" class="btn btn-secondary" @onclick="() => StartEdit(item)">Sua</button>
                                    <button type="button" class="btn btn-danger" @onclick="() => DeleteAsync(item)">Xoa</button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!_qrItems.Any())
                    {
                        <tr>
                            <td colspan="4">Khong co du lieu phu hop.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private readonly MaQRCreate _form = new();
    private List<MaQRItem> _qrItems = new();
    private int? _editingId;
    private bool _showForm;
    private bool _isSaving;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _qrItems = (await ApiClient.GetMaQRAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi tai du lieu: {ex.Message}";
        }
    }

    private void ToggleCreateForm()
    {
        if (_showForm && _editingId is null)
        {
            CloseForm();
            return;
        }

        ResetForm();
        _showForm = true;
        _error = null;
        _success = null;
    }

    private void CloseForm()
    {
        ResetForm();
        _showForm = false;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.MaDiem = 0;
        _form.GiaTriQR = string.Empty;
    }

    private void StartEdit(MaQRItem item)
    {
        _editingId = item.MaQR;
        _form.MaDiem = item.MaDiem;
        _form.GiaTriQR = item.GiaTriQR;
        _showForm = true;
        _error = null;
        _success = null;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _error = null;
        _success = null;

        var payload = new MaQRCreate
        {
            MaDiem = _form.MaDiem,
            GiaTriQR = _form.GiaTriQR.Trim()
        };

        ApiOperationResult result;
        if (_editingId is null)
        {
            result = await ApiClient.CreateMaQRAsync(payload);
        }
        else
        {
            result = await ApiClient.UpdateMaQRAsync(_editingId.Value, payload);
        }

        _isSaving = false;

        if (!result.Success)
        {
            _error = result.ErrorMessage;
            return;
        }

        _success = _editingId is null ? "Da tao Ma QR moi." : "Da cap nhat Ma QR.";
        CloseForm();
        await LoadAsync();
    }

    private async Task DeleteAsync(MaQRItem item)
    {
        if (!await Js.InvokeAsync<bool>("confirm", $"Ban co chac muon xoa Ma QR {item.GiaTriQR}?"))
        {
            return;
        }

        try
        {
            var result = await ApiClient.DeleteMaQRAsync(item.MaQR);
            if (!result.Success)
            {
                _error = result.ErrorMessage;
                return;
            }

            _success = "Da xoa Ma QR thanh cong.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi xoa Ma QR: {ex.Message}";
        }
    }
}