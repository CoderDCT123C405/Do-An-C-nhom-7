@page "/taikhoan"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@inject IJSRuntime Js

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
<PageTitle>Quan ly Tai Khoan</PageTitle>

<div class="page-title">
    <div>
        <h3>Quan ly Tai Khoan</h3>
        <p>Danh sach va quan ly thong tin tai khoan trong he thong.</p>
    </div>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">@(_showForm ? "Dong form" : "Them Tai Khoan")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_success))
{
    <div class="notice notice-success">@_success</div>
}

<div class="card">
    @if (_showForm)
    {
        <div class="card">
            <h4>@(_editingId is null ? "Them Tai Khoan" : $"Cap nhat Tai Khoan #{_editingId}")</h4>

            <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="tai-khoan-form" style="display:grid;gap:10px;margin-top:10px;">
                <DataAnnotationsValidator />

                <div>
                    <label>Ten Tai Khoan</label>
                    <InputText @bind-Value="_form.TenTaiKhoan" />
                    <ValidationMessage For="() => _form.TenTaiKhoan" />
                </div>

                <div>
                    <label>Ho Ten</label>
                    <InputText @bind-Value="_form.HoTen" />
                    <ValidationMessage For="() => _form.HoTen" />
                </div>

                <div>
                    <label>Email</label>
                    <InputText @bind-Value="_form.Email" />
                    <ValidationMessage For="() => _form.Email" />
                </div>

                <div>
                    <label>Mat Khau</label>
                    <InputText @bind-Value="_form.MatKhau" type="password" />
                    <ValidationMessage For="() => _form.MatKhau" />
                </div>

                <div>
                    <label>Vai Tro</label>
                    <InputSelect @bind-Value="_form.VaiTro">
                        <option value="">-- Chon Vai Tro --</option>
                        <option value="Admin">Admin</option>
                        <option value="User">User</option>
                    </InputSelect>
                    <ValidationMessage For="() => _form.VaiTro" />
                </div>

                <label style="display:flex;align-items:center;gap:6px;">
                    Trạng thái hoạt động
                    <InputCheckbox @bind-Value="_form.TrangThaiHoatDong" style=""/>  
                </label>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CloseForm">Huy</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">@(_isSaving ? "Dang luu..." : "Luu")</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="card">
        @{
            var filteredItems = FilteredItems.ToList();
            var currentPage = GetCurrentPage(filteredItems.Count);
            var pagedItems = GetPagedItems(filteredItems);
        }

        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
            <h4>Danh sach Tai Khoan</h4>
            <input placeholder="Tim ten tai khoan, vai tro..." style="max-width:280px;" @bind="SearchText" @bind:event="oninput" />
        </div>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ma</th>
                        <th>Ten Tai Khoan</th>
                        <th>Vai Tro</th>
                        <th>Trang Thai</th>
                        <th>Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedItems)
                    {
                        var isProtectedAdmin = IsProtectedAdmin(item);
                        <tr>
                            <td>@item.MaTaiKhoan</td>
                            <td>@item.TenTaiKhoan</td>
                            <td>@item.VaiTro</td>
                            <td>@(item.TrangThaiHoatDong ? "Hoat dong" : "Tam dung")</td>
                            <td>
                                <div style="display:flex;gap:8px;">
                                    <button type="button"
                                            class="btn btn-secondary"
                                            @onclick="() => StartEdit(item)"
                                            disabled="@isProtectedAdmin"
                                            title="@(isProtectedAdmin ? "Tai khoan Admin duoc khoa, khong cho sua." : null)">
                                        Sua
                                    </button>
                                    <button type="button"
                                            class="btn @(item.TrangThaiHoatDong ? "btn-danger" : "btn-primary")"
                                            @onclick="() => ToggleVisibilityAsync(item)"
                                            disabled="@isProtectedAdmin"
                                            title="@(isProtectedAdmin ? "Tai khoan Admin duoc khoa, khong cho an/hien." : null)">
                                        @(isProtectedAdmin ? "Khoa" : item.TrangThaiHoatDong ? "An" : "Hien")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!filteredItems.Any())
                    {
                        <tr>
                            <td colspan="5">Khong co du lieu phu hop.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <PaginationControls TotalItems="@filteredItems.Count"
                            ItemLabel="tai khoan"
                            PageSize="@_pageSize"
                            PageSizeChanged="OnPageSizeChanged"
                            CurrentPage="@currentPage"
                            CurrentPageChanged="OnPageChanged" />

    </div>
</div>

@code {
    private readonly TaiKhoanCreate _form = new();
    private List<TaiKhoanItem> _taiKhoanItems = new();
    private int? _editingId;
    private bool _showForm;
    private bool _isSaving;
    private string? _error;
    private string? _success;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 10;
    private int _jumpPage = 1;

    private string SearchText
    {
        get => _search;
        set
        {
            _search = value;
            ResetPagination();
        }
    }

    private IEnumerable<TaiKhoanItem> FilteredItems => _taiKhoanItems.Where(x =>
        string.IsNullOrWhiteSpace(_search)
        || x.TenTaiKhoan.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
        || x.VaiTro.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (!Session.IsAdmin)
        {
            Navigation.NavigateTo("/khong-co-quyen", true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _taiKhoanItems = (await ApiClient.GetTaiKhoanAsync()).ToList();
            ResetPagination();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi tai du lieu: {ex.Message}";
        }
    }

    private int GetTotalPages(int totalItems)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)_pageSize));

    private int GetCurrentPage(int totalItems)
    {
        _page = Math.Clamp(_page, 1, GetTotalPages(totalItems));
        _jumpPage = _page;
        return _page;
    }

    private List<TaiKhoanItem> GetPagedItems(IReadOnlyList<TaiKhoanItem> items)
    {
        var currentPage = GetCurrentPage(items.Count);
        return items.Skip((currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private Task OnPageChanged(int page)
    {
        _page = page;
        _jumpPage = page;
        return Task.CompletedTask;
    }

    private Task OnPageSizeChanged(int size)
    {
        _pageSize = size;
        ResetPagination();
        return Task.CompletedTask;
    }

    private void ResetPagination()
    {
        _page = 1;
        _jumpPage = 1;
    }

    private void ToggleCreateForm()
    {
        if (_showForm && _editingId is null)
        {
            CloseForm();
            return;
        }

        ResetForm();
        _showForm = true;
        _error = null;
        _success = null;
    }

    private void CloseForm()
    {
        ResetForm();
        _showForm = false;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.TenTaiKhoan = string.Empty;
        _form.HoTen = string.Empty;
        _form.Email = string.Empty;
        _form.MatKhau = string.Empty;
        _form.VaiTro = string.Empty;
        _form.TrangThaiHoatDong = true;
    }

    private void StartEdit(TaiKhoanItem item)
    {
        if (IsProtectedAdmin(item))
        {
            _error = "Tai khoan Admin duoc bao ve, khong the sua.";
            _success = null;
            return;
        }

        _editingId = item.MaTaiKhoan;
        _form.TenTaiKhoan = item.TenTaiKhoan;
        _form.HoTen = item.HoTen;
        _form.Email = item.Email;
        _form.MatKhau = string.Empty;
        _form.VaiTro = item.VaiTro;
        _form.TrangThaiHoatDong = item.TrangThaiHoatDong;
        _showForm = true;
        _error = null;
        _success = null;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _error = null;
        _success = null;

        var payload = new TaiKhoanCreate
        {
            TenTaiKhoan = _form.TenTaiKhoan.Trim(),
            HoTen = _form.HoTen.Trim(),
            Email = string.IsNullOrWhiteSpace(_form.Email) ? null : _form.Email.Trim(),
            MatKhau = _form.MatKhau.Trim(),
            VaiTro = _form.VaiTro,
            TrangThaiHoatDong = _form.TrangThaiHoatDong
        };

        ApiOperationResult result;
        if (_editingId is null)
        {
            result = await ApiClient.CreateTaiKhoanAsync(payload);
        }
        else
        {
            var editingItem = _taiKhoanItems.FirstOrDefault(x => x.MaTaiKhoan == _editingId.Value);
            if (editingItem is not null && IsProtectedAdmin(editingItem))
            {
                _isSaving = false;
                _error = "Tai khoan Admin duoc bao ve, khong the sua.";
                return;
            }

            result = await ApiClient.UpdateTaiKhoanAsync(_editingId.Value, payload);
        }

        _isSaving = false;

        if (!result.Success)
        {
            _error = result.ErrorMessage;
            return;
        }

        _success = _editingId is null ? "Da tao Tai Khoan moi." : "Da cap nhat Tai Khoan.";
        CloseForm();
        await LoadAsync();
    }

    private async Task ToggleVisibilityAsync(TaiKhoanItem item)
    {
        if (IsProtectedAdmin(item))
        {
            _error = "Tai khoan Admin duoc bao ve, khong the an hoac hien.";
            _success = null;
            return;
        }

        var nextStateLabel = item.TrangThaiHoatDong ? "an" : "hien";
        if (!await Js.InvokeAsync<bool>("confirm", $"Ban co chac muon {nextStateLabel} Tai Khoan {item.TenTaiKhoan}?"))
        {
            return;
        }

        try
        {
            _error = null;
            _success = null;

            var result = await ApiClient.UpdateTaiKhoanAsync(item.MaTaiKhoan, new TaiKhoanCreate
            {
                TenTaiKhoan = item.TenTaiKhoan,
                HoTen = item.HoTen,
                Email = item.Email,
                MatKhau = string.Empty,
                VaiTro = item.VaiTro,
                TrangThaiHoatDong = !item.TrangThaiHoatDong
            });

            if (!result.Success)
            {
                _error = result.ErrorMessage;
                return;
            }

            _success = item.TrangThaiHoatDong ? "Da an Tai Khoan thanh cong." : "Da hien Tai Khoan thanh cong.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi cap nhat trang thai Tai Khoan: {ex.Message}";
        }
    }

    private static bool IsProtectedAdmin(TaiKhoanItem item)
        => string.Equals(item.VaiTro, "Admin", StringComparison.OrdinalIgnoreCase);
}
