@page "/noidungthuyetminh"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>Noi dung thuyet minh</PageTitle>

<div class="page-title">
    <div>
        <h3>Quan ly noi dung thuyet minh</h3>
        <p>Them, sua noi dung va tao lai audio edge-tts truc tiep tu CMS.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_success))
{
    <div class="notice notice-success">@_success</div>
}

<div class="card" style="margin-bottom:12px;display:grid;gap:10px;">
    <div class="grid-2">
        <div>
            <label>Diem tham quan</label>
            <select value="@_selectedMaDiem" @onchange="OnDiemChanged">
                <option value="0">Tat ca diem</option>
                @foreach (var diem in _diemItems)
                {
                    <option value="@diem.MaDiem">@diem.TenDiem (@diem.MaDinhDanh)</option>
                }
            </select>
        </div>
        <div style="display:flex;gap:8px;align-items:flex-end;">
            <button class="btn btn-primary" @onclick="StartCreate">Them noi dung</button>
            <button class="btn btn-secondary" @onclick="LoadNoiDungAsync" disabled="@_isLoading">Tai lai</button>
            <button class="btn btn-secondary" @onclick="GenerateAllAudioAsync" disabled="@(_isGeneratingAllAudio || _isLoading)">
                @(_isGeneratingAllAudio ? "Dang tao lai audio..." : "Tao lai toan bo audio")
            </button>
        </div>
    </div>
    <div>
        <label>Tim kiem noi dung</label>
        <input placeholder="Tim theo tieu de/noi dung..." @bind="_search" @bind:event="oninput" />
    </div>
</div>

@if (CoverageRows.Any())
{
    <div class="card" style="margin-bottom:12px;">
        <h4>Do day du ngon ngu cho demo</h4>
        <p style="margin-top:6px;color:#475569;">Muc tieu demo: moi diem co du 3 ngon ngu vi, en, zh-CN va san sang sinh audio.</p>

        <div class="table-wrap" style="margin-top:10px;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Diem tham quan</th>
                        <th>Ngon ngu hien co</th>
                        <th>Ngon ngu con thieu</th>
                        <th>Trang thai</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in CoverageRows)
                    {
                        <tr>
                            <td>@row.PoiDisplayName</td>
                            <td>@row.AvailableLanguagesText</td>
                            <td>@row.MissingLanguagesText</td>
                            <td>
                                <span class="badge @(row.IsComplete ? "badge-success" : "badge-muted")">
                                    @(row.IsComplete ? "Du 3 ngon ngu" : "Can bo sung")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showForm)
{
    <div class="card" style="margin-bottom:12px;">
        <h4>@(_editingId is null ? "Them noi dung" : $"Cap nhat noi dung #{_editingId}")</h4>

        <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="noidung-thuyetminh-form" style="display:grid;gap:10px;margin-top:10px;">
            <DataAnnotationsValidator />

            <div class="grid-2">
                <div>
                    <label>Diem tham quan</label>
                    <InputSelect @bind-Value="_form.MaDiem">
                        <option value="0">-- Chon diem --</option>
                        @foreach (var diem in _diemItems)
                        {
                            <option value="@diem.MaDiem">@diem.TenDiem (@diem.MaDinhDanh)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => _form.MaDiem" />
                </div>

                <div>
                    <label>Ngon ngu</label>
                    <InputSelect @bind-Value="_form.MaNgonNgu">
                        <option value="0">-- Chon ngon ngu --</option>
                        @foreach (var ngonNgu in _ngonNguItems)
                        {
                            <option value="@ngonNgu.MaNgonNgu">@ngonNgu.TenNgonNgu (@ngonNgu.MaNgonNguQuocTe)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => _form.MaNgonNgu" />
                </div>
            </div>

            <div>
                <label>Tieu de</label>
                <InputText @bind-Value="_form.TieuDe" />
                <ValidationMessage For="() => _form.TieuDe" />
            </div>

            <div>
                <label>Noi dung van ban</label>
                <InputTextArea @bind-Value="_form.NoiDungVanBan" rows="6" />
            </div>

            <div class="grid-2">
                <div></div>
                <div style="display:grid;gap:8px;align-content:center;">
                    <label style="display:flex;align-items:center;gap:8px;">
                        <InputCheckbox @bind-Value="_form.ChoPhepTTS" />
                        Cho phep TTS
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;">
                        <InputCheckbox @bind-Value="_form.TrangThaiHoatDong" />
                        Trang thai hoat dong
                    </label>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-secondary" @onclick="CloseForm">Huy</button>
                <button type="submit" class="btn btn-primary" disabled="@_isBusy">@(_isBusy ? "Dang luu..." : "Luu")</button>
            </div>
        </EditForm>
    </div>
}

<div class="card">
    <h4>Danh sach noi dung</h4>

    <div class="table-wrap" style="margin-top:10px;">
        <table class="table">
            <thead>
                <tr>
                    <th>Ma</th>
                    <th>Diem tham quan</th>
                    <th>Tieu de</th>
                    <th>Ngon ngu</th>
                    <th style="min-width:340px;">Audio</th>
                    <th>Trang thai</th>
                    <th>Hanh dong</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in FilteredNoiDungItems)
                {
                    <tr>
                        <td>@item.MaNoiDung</td>
                        <td>@GetTenDiem(item.MaDiem)</td>
                        <td>@item.TieuDe</td>
                        <td>@GetLanguageDisplay(item)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(item.DuongDanAmThanh))
                            {
                                <button type="button"
                                        class="btn btn-secondary"
                                        style="min-width:132px;"
                                        disabled="@_generatingAudioIds.Contains(item.MaNoiDung)"
                                        @onclick="() => GenerateAudioAsync(item.MaNoiDung)">
                                    @(_generatingAudioIds.Contains(item.MaNoiDung) ? "Dang tao..." : "Tao audio")
                                </button>
                            }
                            else
                            {
                                <audio controls preload="none" style="max-width:340px;width:100%;border-radius:12px;background:#f8fafc;border:1px solid #d9e2ef;padding:2px;">
                                    <source src="@ResolveAudioUrl(item.DuongDanAmThanh)" type="audio/mpeg" />
                                    Trinh duyet khong ho tro phat audio.
                                </audio>
                            }
                        </td>
                        <td>
                            <span class="badge @(item.TrangThaiHoatDong ? "badge-success" : "badge-muted")">
                                @(item.TrangThaiHoatDong ? "Hoat dong" : "Tam dung")
                            </span>
                        </td>
                        <td>
                            <button type="button" class="btn btn-secondary" @onclick="() => StartEdit(item)">Sua</button>
                        </td>
                    </tr>
                }

                @if (!FilteredNoiDungItems.Any())
                {
                    <tr>
                        <td colspan="7">Chua co noi dung cho bo loc hien tai.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private readonly NoiDungThuyetMinhCreate _form = new();
    private readonly List<DiemThamQuanItem> _diemItems = [];
    private readonly List<NgonNguItem> _ngonNguItems = [];
    private List<NoiDungThuyetMinhItem> _noiDungItems = [];
    private int _selectedMaDiem;
    private int? _editingId;
    private bool _showForm;
    private bool _isLoading;
    private bool _isBusy;
    private string? _error;
    private string? _success;
    private string _search = "";
    private bool _isGeneratingAllAudio;
    private readonly HashSet<int> _generatingAudioIds = [];
    private static readonly string[] RequiredLanguageCodes = ["vi", "en", "zh-CN"];

    private IEnumerable<PoiCoverageRow> CoverageRows => _diemItems
        .Where(x => _selectedMaDiem == 0 || x.MaDiem == _selectedMaDiem)
        .Select(BuildCoverageRow)
        .OrderBy(x => x.IsComplete ? 1 : 0)
        .ThenBy(x => x.PoiDisplayName);

    private IEnumerable<NoiDungThuyetMinhItem> FilteredNoiDungItems =>
        _noiDungItems.Where(x =>
            string.IsNullOrWhiteSpace(_search)
            || (!string.IsNullOrWhiteSpace(x.TieuDe) && x.TieuDe.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase))
            || (!string.IsNullOrWhiteSpace(x.NoiDungVanBan) && x.NoiDungVanBan.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        await LoadSeedDataAsync();
        await LoadNoiDungAsync();
    }

    private async Task LoadSeedDataAsync()
    {
        _diemItems.Clear();
        _ngonNguItems.Clear();

        _diemItems.AddRange((await ApiClient.GetDiemAsync()).OrderBy(x => x.TenDiem));
        _ngonNguItems.AddRange((await ApiClient.GetNgonNguAsync())
            .Where(x => x.TrangThaiHoatDong)
            .OrderByDescending(x => x.LaMacDinh)
            .ThenBy(x => Array.IndexOf(RequiredLanguageCodes, x.MaNgonNguQuocTe))
            .ThenBy(x => x.TenNgonNgu));

        if (_selectedMaDiem < 0)
        {
            _selectedMaDiem = 0;
        }
    }

    private async Task OnDiemChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var value))
        {
            _selectedMaDiem = value;
        }

        await LoadNoiDungAsync();
    }

    private async Task LoadNoiDungAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            if (_selectedMaDiem == 0)
            {
                var allItems = new List<NoiDungThuyetMinhItem>();
                foreach (var diem in _diemItems)
                {
                    var byDiem = await ApiClient.GetNoiDungTheoDiemAsync(diem.MaDiem);
                    allItems.AddRange(byDiem);
                }

                _noiDungItems = allItems
                    .OrderBy(x => x.MaDiem)
                    .ThenBy(x => x.MaNgonNgu)
                    .ThenBy(x => x.TieuDe)
                    .ToList();
            }
            else
            {
                _noiDungItems = (await ApiClient.GetNoiDungTheoDiemAsync(_selectedMaDiem))
                    .OrderBy(x => x.MaNgonNgu)
                    .ThenBy(x => x.TieuDe)
                    .ToList();
            }
        }
        catch
        {
            _error = "Khong tai duoc danh sach noi dung.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.MaDiem = _selectedMaDiem > 0 ? _selectedMaDiem : 0;
        _form.MaNgonNgu = 0;
        _form.TieuDe = string.Empty;
        _form.NoiDungVanBan = string.Empty;
        _form.DuongDanAmThanh = string.Empty;
        _form.ChoPhepTTS = true;
        // _form.ThoiLuongGiay auto-calculated
        _form.TrangThaiHoatDong = true;
    }

    private void StartCreate()
    {
        ResetForm();
        _showForm = true;
        _error = null;
        _success = null;
    }

    private void CloseForm()
    {
        ResetForm();
        _showForm = false;
    }

    private void StartEdit(NoiDungThuyetMinhItem item)
    {
        _editingId = item.MaNoiDung;
        _form.MaDiem = item.MaDiem;
        _form.MaNgonNgu = item.MaNgonNgu;
        _form.TieuDe = item.TieuDe;
        _form.NoiDungVanBan = item.NoiDungVanBan;
        _form.DuongDanAmThanh = item.DuongDanAmThanh;
        _form.ChoPhepTTS = item.ChoPhepTTS;
        // ThoiLuongGiay auto-calculated by backend
        _form.TrangThaiHoatDong = item.TrangThaiHoatDong;
        _showForm = true;
        _error = null;
        _success = null;
    }

    private async Task SaveAsync()
    {
        _isBusy = true;
        _error = null;
        _success = null;

        var payload = new NoiDungThuyetMinhCreate
        {
            MaDiem = _form.MaDiem,
            MaNgonNgu = _form.MaNgonNgu,
            TieuDe = _form.TieuDe.Trim(),
            NoiDungVanBan = _form.NoiDungVanBan?.Trim(),
            DuongDanAmThanh = string.IsNullOrWhiteSpace(_form.DuongDanAmThanh) ? null : _form.DuongDanAmThanh.Trim(),
            ChoPhepTTS = _form.ChoPhepTTS,
            // ThoiLuongGiay auto-calculated, omit
            TrangThaiHoatDong = _form.TrangThaiHoatDong
        };

        ApiOperationResult result;
        if (_editingId is null)
        {
            result = await ApiClient.CreateNoiDungAsync(payload);
        }
        else
        {
            result = await ApiClient.UpdateNoiDungAsync(_editingId.Value, payload);
        }

        if (!result.Success)
        {
            _isBusy = false;
            _error = CleanError(result.ErrorMessage);
            return;
        }

        if (_selectedMaDiem > 0)
        {
            _selectedMaDiem = payload.MaDiem;
        }
        _success = _editingId is null
            ? "Da tao noi dung moi. Audio se duoc tao tu dong."
            : "Da cap nhat noi dung. Audio cu se duoc thay the tu dong.";

        CloseForm();
        await LoadNoiDungAsync();
        _isBusy = false;
    }

    private async Task GenerateAudioAsync(int maNoiDung)
    {
        if (_generatingAudioIds.Contains(maNoiDung))
        {
            return;
        }

        _generatingAudioIds.Add(maNoiDung);
        _error = null;
        _success = null;
        try
        {
            var result = await ApiClient.GenerateAudioForNoiDungAsync(maNoiDung);
            if (!result.Success)
            {
                _error = CleanError(result.ErrorMessage);
                return;
            }

            _success = "Da tao audio thanh cong.";
            await LoadNoiDungAsync();
        }
        finally
        {
            _generatingAudioIds.Remove(maNoiDung);
        }
    }

    private async Task GenerateAllAudioAsync()
    {
        if (_isGeneratingAllAudio)
        {
            return;
        }

        _isGeneratingAllAudio = true;
        _error = null;
        _success = null;

        try
        {
            var result = await ApiClient.GenerateAudioBatchAsync(overwrite: true);
            if (!result.Success)
            {
                _error = CleanError(result.ErrorMessage);
                return;
            }

            _success = "Da gui yeu cau tao lai toan bo audio demo.";
            await LoadNoiDungAsync();
        }
        finally
        {
            _isGeneratingAllAudio = false;
        }
    }

    private static string CleanError(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return "Co loi xay ra. Vui long thu lai.";
        }

        return raw
            .Replace("{", string.Empty)
            .Replace("}", string.Empty)
            .Replace("\"", string.Empty)
            .Trim();
    }

    private string ResolveAudioUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return "#";
        }

        if (Uri.TryCreate(path, UriKind.Absolute, out var absolute))
        {
            return absolute.ToString();
        }

        var baseUrl = Config["Api:BaseUrl"] ?? "http://localhost:5000/";
        return $"{baseUrl.TrimEnd('/')}/{path.TrimStart('/')}";
    }

    private string GetTenDiem(int maDiem)
    {
        var diem = _diemItems.FirstOrDefault(x => x.MaDiem == maDiem);
        return diem is null ? $"Diem #{maDiem}" : $"{diem.TenDiem} ({diem.MaDinhDanh})";
    }

    private string GetLanguageDisplay(NoiDungThuyetMinhItem item)
    {
        var language = _ngonNguItems.FirstOrDefault(x => x.MaNgonNgu == item.MaNgonNgu);
        if (language is null)
        {
            return item.TenNgonNgu ?? $"Ngon ngu #{item.MaNgonNgu}";
        }

        return string.IsNullOrWhiteSpace(language.MaNgonNguQuocTe)
            ? language.TenNgonNgu
            : $"{language.TenNgonNgu} ({language.MaNgonNguQuocTe})";
    }

    private PoiCoverageRow BuildCoverageRow(DiemThamQuanItem poi)
    {
        var availableLanguageCodes = _noiDungItems
            .Where(x => x.MaDiem == poi.MaDiem && x.TrangThaiHoatDong)
            .Select(x => GetLanguageCode(x.MaNgonNgu))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var missingLanguageCodes = RequiredLanguageCodes
            .Where(code => !availableLanguageCodes.Contains(code, StringComparer.OrdinalIgnoreCase))
            .ToList();

        return new PoiCoverageRow(
            $"{poi.TenDiem} ({poi.MaDinhDanh})",
            availableLanguageCodes.Count == 0 ? "Chua co" : string.Join(", ", availableLanguageCodes),
            missingLanguageCodes.Count == 0 ? "Khong thieu" : string.Join(", ", missingLanguageCodes),
            missingLanguageCodes.Count == 0);
    }

    private string? GetLanguageCode(int maNgonNgu)
        => _ngonNguItems.FirstOrDefault(x => x.MaNgonNgu == maNgonNgu)?.MaNgonNguQuocTe;

    private sealed record PoiCoverageRow(
        string PoiDisplayName,
        string AvailableLanguagesText,
        string MissingLanguagesText,
        bool IsComplete);
}
