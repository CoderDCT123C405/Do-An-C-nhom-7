@page "/login"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation

<PageTitle>Dang nhap Admin</PageTitle>

<div class="card glass" style="max-width:460px;margin:8vh auto;animation:rise-in .4s ease;">
    <div class="page-title" style="margin-bottom:10px;">
        <div>
            <h3>Dang nhap Admin CMS</h3>
            <p>Quan tri noi dung thuyet minh du lich an toan va nhanh.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="notice notice-error">@_error</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
        <DataAnnotationsValidator />

        <div style="display:grid;gap:10px;">
            <div>
                <label for="username">Ten dang nhap</label>
                <InputText id="username" @bind-Value="_model.TenDangNhap" />
                <ValidationMessage For="() => _model.TenDangNhap" />
            </div>

            <div>
                <label for="password">Mat khau</label>
                <InputText id="password" type="password" @bind-Value="_model.MatKhau" />
                <ValidationMessage For="() => _model.MatKhau" />
            </div>
        </div>

        <div class="form-actions" style="margin-top:16px;justify-content:stretch;">
            <button type="submit" class="btn btn-primary" style="width:100%;" disabled="@_isLoading">
                @(_isLoading ? "Dang xu ly..." : "Dang nhap")
            </button>
        </div>
    </EditForm>
</div>

@code {
    private readonly AdminLoginRequest _model = new();
    private bool _isLoading;
    private string? _error;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleLoginAsync()
    {
        _error = null;
        _isLoading = true;

        var response = await ApiClient.LoginAsync(new AdminLoginRequest
        {
            TenDangNhap = _model.TenDangNhap.Trim(),
            MatKhau = _model.MatKhau.Trim()
        });

        _isLoading = false;

        if (response is null || string.IsNullOrWhiteSpace(response.Token))
        {
            _error = "Dang nhap that bai. Vui long kiem tra tai khoan hoac ket noi API.";
            return;
        }

        Session.SignIn(response.TenDangNhap, response.Token, response.HoTen, response.VaiTro, response.HetHanLuc);
        Navigation.NavigateTo("/");
    }
}
