@page "/login"
@using HeThongThuyetMinhDuLich.Cms.Models
@using Microsoft.AspNetCore.Components.Forms

@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation

<PageTitle>Dang nhap</PageTitle>

<div style="min-height:calc(100vh - 56px);display:grid;place-items:center;">
    <div class="card" style="width:min(460px, 96vw);display:grid;gap:14px;">
        <div class="page-title" style="margin-bottom:0;">
            <div>
                <h3>Dang nhap he thong</h3>
                <p>Nhap thong tin tai khoan quan tri de tiep tuc.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loginError))
        {
            <div class="notice notice-error">@_loginError</div>
        }

        <EditForm Model="_loginModel" OnValidSubmit="HandleLoginAsync" FormName="login-form" style="display:grid;gap:10px;">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
                <label for="username">Ten dang nhap</label>
                <InputText id="username" @bind-Value="_loginModel.TenDangNhap" autocomplete="username" />
            </div>

            <div>
                <label for="password">Mat khau</label>
                <InputText id="password" @bind-Value="_loginModel.MatKhau" type="password" autocomplete="current-password" />
            </div>

            <div class="form-actions" style="margin-top:6px;">
                <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Dang dang nhap..." : "Dang nhap")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly AdminLoginRequest _loginModel = new();
    private string? _loginError;
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleLoginAsync()
    {
        _isSubmitting = true;
        _loginError = null;

        try
        {
            var result = await ApiClient.LoginAsync(_loginModel);
            if (result is null || string.IsNullOrWhiteSpace(result.Token))
            {
                _loginError = "Dang nhap that bai. Vui long kiem tra lai ten dang nhap/mat khau.";
                return;
            }

            var expiresAt = result.HetHanLuc == default ? (DateTime?)null : result.HetHanLuc;
            Session.SignIn(result.MaDinhDanh, result.TenDangNhap, result.Token, result.HoTen, result.VaiTro, expiresAt);
            Navigation.NavigateTo("/");
        }
        catch
        {
            _loginError = "Khong the ket noi den may chu dang nhap.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}

