@page "/"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components

<PageTitle>Tong quan</PageTitle>

<div class="page-title">
    <div>
        <h3>Tong quan he thong</h3>
        <p>Theo doi nhanh du lieu admin va hien trang van hanh.</p>
    </div>
    <button class="btn btn-secondary" @onclick="LoadAsync" disabled="@_isLoading">Tai lai</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}

<div class="grid-3">
    <div class="card">
        <small>Tong diem tham quan</small>
        <div class="kpi-value">@_tongDiem</div>
    </div>

    <div class="card">
        <small>Tong loai diem</small>
        <div class="kpi-value">@_tongLoai</div>
    </div>

    <div class="card">
        <small>Tong luot nghe</small>
        <div class="kpi-value">@_tongLuotNghe</div>
    </div>
</div>

@code {
    private bool _isLoading;
    private string? _error;
    private int _tongDiem;
    private int _tongLoai;
    private int _tongLuotNghe;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var diem = await ApiClient.GetDiemAsync();
            var loai = await ApiClient.GetLoaiDiemAsync();
            var thongKe = await ApiClient.GetThongKeTheoDiemAsync();

            _tongDiem = diem.Count;
            _tongLoai = loai.Count;
            _tongLuotNghe = thongKe.Sum(x => x.SoLuotNghe);
        }
        catch
        {
            _error = "Khong tai duoc du lieu tong quan.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

