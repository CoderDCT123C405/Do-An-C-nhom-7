@page "/nguoidung"
@inject CmsApiClient ApiClient
@inject CmsSession Session
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Quan ly Nguoi Dung</PageTitle>

@using HeThongThuyetMinhDuLich.Cms.Models

<div class="page-title">
    <div>
        <h3>Quan ly Nguoi Dung</h3>
        <p>Danh sach va quan ly thong tin nguoi dung trong he thong.</p>
    </div>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">@(_showForm ? "Dong form" : "Them Nguoi Dung")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="notice notice-error">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_success))
{
    <div class="notice notice-success">@_success</div>
}

<div class="card">
    @if (_showForm)
    {
        <div class="card">
            <h4>@(_editingId is null ? "Them Nguoi Dung" : $"Cap nhat Nguoi Dung #{_editingId}")</h4>

            <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="nguoi-dung-form" style="display:grid;gap:10px;margin-top:10px;">
                <DataAnnotationsValidator />

                <div>
                    <label>Ten Dang Nhap</label>
                    <InputText @bind-Value="_form.TenDangNhap" />
                    <ValidationMessage For="() => _form.TenDangNhap" />
                </div>

                <div>
                    <label>Ho Ten</label>
                    <InputText @bind-Value="_form.HoTen" />
                    <ValidationMessage For="() => _form.HoTen" />
                </div>

                <div>
                    <label>Email</label>
                    <InputText @bind-Value="_form.Email" />
                    <ValidationMessage For="() => _form.Email" />
                </div>

                <div>
                    <label>So Dien Thoai</label>
                    <InputText @bind-Value="_form.SoDienThoai" />
                    <ValidationMessage For="() => _form.SoDienThoai" />
                </div>

                <div>
                    <label>Ngon Ngu Mac Dinh</label>
                    <InputSelect @bind-Value="_form.MaNgonNguMacDinh">
                        <option value="0">-- Chon Ngon Ngu --</option>
                        @foreach (var ngonNgu in _ngonNguItems)
                        {
                            <option value="@ngonNgu.MaNgonNgu">@ngonNgu.TenNgonNgu</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => _form.MaNgonNguMacDinh" />
                </div>

                <label style="display:flex;align-items:center;gap:6px;">
                    Trạng thái hoạt động
                    <InputCheckbox @bind-Value="_form.TrangThaiHoatDong" style=""/>  
                </label>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CloseForm">Huy</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">@(_isSaving ? "Dang luu..." : "Luu")</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="card">
        @{
            var filteredItems = FilteredItems.ToList();
            var currentPage = GetCurrentPage(filteredItems.Count);
            var pagedItems = GetPagedItems(filteredItems);
        }

        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
            <h4>Danh sach Nguoi Dung</h4>
            <input placeholder="Tim ten dang nhap, ho ten, email..." style="max-width:320px;" @bind="SearchText" @bind:event="oninput" />
        </div>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ma</th>
                        <th>Ten Dang Nhap</th>
                        <th>Ho Ten</th>
                        <th>Email</th>
                        <th>So Dien Thoai</th>
                        <th>Ngon Ngu</th>
                        <th>Trang Thai</th>
                        <th>Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedItems)
                    {
                        <tr>
                            <td>@item.MaNguoiDung</td>
                            <td>@item.TenDangNhap</td>
                            <td>@item.HoTen</td>
                            <td>@item.Email</td>
                            <td>@item.SoDienThoai</td>
                            <td>@item.TenNgonNgu</td>
                            <td>@(item.TrangThaiHoatDong ? "Hoat dong" : "Tam dung")</td>
                            <td>
                                <div style="display:flex;gap:8px;">
                                    <button type="button" class="btn btn-secondary" @onclick="() => StartEdit(item)">Sua</button>
                                    <button type="button"
                                            class="btn @(item.TrangThaiHoatDong ? "btn-danger" : "btn-primary")"
                                            @onclick="() => ToggleVisibilityAsync(item)">
                                        @(item.TrangThaiHoatDong ? "An" : "Hien")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!filteredItems.Any())
                    {
                        <tr>
                            <td colspan="8">Khong co du lieu phu hop.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <PaginationControls TotalItems="@filteredItems.Count"
                            ItemLabel="nguoi dung"
                            PageSize="@_pageSize"
                            PageSizeChanged="OnPageSizeChanged"
                            CurrentPage="@currentPage"
                            CurrentPageChanged="OnPageChanged" />

    </div>
</div>

@code {
    private readonly NguoiDungCreate _form = new();
    private List<NguoiDungItem> _nguoiDungItems = new();
    private List<NgonNguItem> _ngonNguItems = new();
    private int? _editingId;
    private bool _showForm;
    private bool _isSaving;
    private string? _error;
    private string? _success;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 10;
    private int _jumpPage = 1;

    private string SearchText
    {
        get => _search;
        set
        {
            _search = value;
            ResetPagination();
        }
    }

    private IEnumerable<NguoiDungItem> FilteredItems => _nguoiDungItems.Where(x =>
        string.IsNullOrWhiteSpace(_search)
        || x.TenDangNhap.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
        || x.HoTen.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
        || x.Email.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
        || x.SoDienThoai.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
        || x.TenNgonNgu.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (!Session.IsAdmin)
        {
            Navigation.NavigateTo("/khong-co-quyen", true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _nguoiDungItems = (await ApiClient.GetNguoiDungAsync()).ToList();
            _ngonNguItems = (await ApiClient.GetNgonNguAsync()).ToList();
            ResetPagination();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi tai du lieu: {ex.Message}";
        }
    }

    private int GetTotalPages(int totalItems)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)_pageSize));

    private int GetCurrentPage(int totalItems)
    {
        _page = Math.Clamp(_page, 1, GetTotalPages(totalItems));
        _jumpPage = _page;
        return _page;
    }

    private List<NguoiDungItem> GetPagedItems(IReadOnlyList<NguoiDungItem> items)
    {
        var currentPage = GetCurrentPage(items.Count);
        return items.Skip((currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private Task OnPageChanged(int page)
    {
        _page = page;
        _jumpPage = page;
        return Task.CompletedTask;
    }

    private Task OnPageSizeChanged(int size)
    {
        _pageSize = size;
        ResetPagination();
        return Task.CompletedTask;
    }

    private void ResetPagination()
    {
        _page = 1;
        _jumpPage = 1;
    }

    private void ToggleCreateForm()
    {
        if (_showForm && _editingId is null)
        {
            CloseForm();
            return;
        }

        ResetForm();
        _showForm = true;
        _error = null;
        _success = null;
    }

    private void CloseForm()
    {
        ResetForm();
        _showForm = false;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.TenDangNhap = string.Empty;
        _form.HoTen = string.Empty;
        _form.Email = string.Empty;
        _form.SoDienThoai = string.Empty;
        _form.MaNgonNguMacDinh = 0;
        _form.TrangThaiHoatDong = true;
    }

    private void StartEdit(NguoiDungItem item)
    {
        _editingId = item.MaNguoiDung;
        _form.TenDangNhap = item.TenDangNhap;
        _form.HoTen = item.HoTen;
        _form.Email = item.Email;
        _form.SoDienThoai = item.SoDienThoai;
        _form.MaNgonNguMacDinh = item.MaNgonNguMacDinh;
        _form.TrangThaiHoatDong = item.TrangThaiHoatDong;
        _showForm = true;
        _error = null;
        _success = null;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _error = null;
        _success = null;

        var payload = new NguoiDungCreate
        {
            TenDangNhap = _form.TenDangNhap.Trim(),
            HoTen = _form.HoTen.Trim(),
            Email = _form.Email.Trim(),
            SoDienThoai = _form.SoDienThoai.Trim(),
            MaNgonNguMacDinh = _form.MaNgonNguMacDinh,
            TrangThaiHoatDong = _form.TrangThaiHoatDong
        };

        ApiOperationResult result;
        if (_editingId is null)
        {
            result = await ApiClient.CreateNguoiDungAsync(payload);
        }
        else
        {
            result = await ApiClient.UpdateNguoiDungAsync(_editingId.Value, payload);
        }

        _isSaving = false;

        if (!result.Success)
        {
            _error = result.ErrorMessage;
            return;
        }

        _success = _editingId is null ? "Da tao Nguoi Dung moi." : "Da cap nhat Nguoi Dung.";
        CloseForm();
        await LoadAsync();
    }

    private async Task ToggleVisibilityAsync(NguoiDungItem item)
    {
        var nextStateLabel = item.TrangThaiHoatDong ? "an" : "hien";
        if (!await Js.InvokeAsync<bool>("confirm", $"Ban co chac muon {nextStateLabel} Nguoi Dung {item.HoTen}?"))
        {
            return;
        }

        try
        {
            _error = null;
            _success = null;

            var result = await ApiClient.UpdateNguoiDungAsync(item.MaNguoiDung, new NguoiDungCreate
            {
                TenDangNhap = item.TenDangNhap,
                HoTen = item.HoTen,
                Email = item.Email,
                SoDienThoai = item.SoDienThoai,
                MaNgonNguMacDinh = item.MaNgonNguMacDinh,
                TrangThaiHoatDong = !item.TrangThaiHoatDong
            });

            if (!result.Success)
            {
                _error = result.ErrorMessage;
                return;
            }

            _success = item.TrangThaiHoatDong ? "Da an Nguoi Dung thanh cong." : "Da hien Nguoi Dung thanh cong.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Loi khi cap nhat trang thai Nguoi Dung: {ex.Message}";
        }
    }
}
