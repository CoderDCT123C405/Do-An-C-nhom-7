@page "/thong-ke"
@inject CmsApiClient ApiClient

<PageTitle>Thong ke</PageTitle>

<h1>Thong ke nghe thuyet minh</h1>

<button class="btn btn-outline-primary mb-3" @onclick="ReloadAsync">Tai lai</button>

<h4>Theo diem tham quan</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Ma diem</th>
            <th>Ten diem</th>
            <th>So luot nghe</th>
            <th>Tong thoi luong</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in _theoDiem)
        {
            <tr>
                <td>@item.MaDiem</td>
                <td>@item.TenDiem</td>
                <td>@item.SoLuotNghe</td>
                <td>@item.TongThoiLuongDaNghe</td>
            </tr>
        }
    </tbody>
</table>

<h4>Theo cach kich hoat</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Cach kich hoat</th>
            <th>So luot phat</th>
            <th>Tong thoi luong</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in _theoCach)
        {
            <tr>
                <td>@item.CachKichHoat</td>
                <td>@item.SoLuotPhat</td>
                <td>@item.TongThoiLuongDaNghe</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private readonly List<ThongKeTheoDiemItem> _theoDiem = [];
    private readonly List<ThongKeTheoKichHoatItem> _theoCach = [];

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _theoDiem.Clear();
        _theoCach.Clear();
        _theoDiem.AddRange(await ApiClient.GetThongKeTheoDiemAsync());
        _theoCach.AddRange(await ApiClient.GetThongKeTheoKichHoatAsync());
    }
}
