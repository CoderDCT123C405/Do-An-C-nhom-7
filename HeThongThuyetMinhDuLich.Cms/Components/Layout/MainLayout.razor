@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject CmsSession Session
@using Microsoft.AspNetCore.Components

<div class="shell @(IsLoginPage ? "shell-login" : string.Empty)">
    @if (!IsLoginPage)
    {
        <aside class="sidebar glass">
            <div class="brand">
                <div class="brand-mark">AG</div>
                <div>
                    <h1>Audio Guide CMS</h1>
                    <p>@PortalSubtitle</p>
                </div>
            </div>

            <NavMenu />

            <div class="sidebar-footer">
                <div class="user-info">
                    <strong>@(Session.HoTen ?? Session.TenDangNhap ?? "Admin")</strong>
                    <span>@(Session.VaiTro ?? "Admin")</span>
                </div>
                <button class="btn btn-secondary" @onclick="Logout">Dang xuat</button>
            </div>
        </aside>
    }

    <main class="main @(IsLoginPage ? "login-main" : string.Empty)">
        @if (!IsLoginPage)
        {
            <header class="topbar glass">
                <div>
                    <h2>Quan tri he thong thuyet minh du lich</h2>
                    <p>@TopbarDescription</p>
                </div>
                <div class="status-pill">@StatusPillText</div>
            </header>
        }

        <section class="page-body">
            @Body
        </section>
    </main>
</div>

@code {
    private bool IsLoginPage => Navigation.Uri.EndsWith("/login", StringComparison.OrdinalIgnoreCase);

    private string PortalSubtitle => Session.IsBienTap ? "Bien tap Portal" : "Admin Portal";

    private string TopbarDescription => Session.IsBienTap
        ? "Ban dang o che do BienTap: quan ly noi dung, QR, diem va loai diem; khong quan ly he thong."
        : "Giam sat noi dung, du lieu va thong ke theo thoi gian thuc.";

    private string StatusPillText => Session.IsBienTap ? "Role: BienTap" : "Role: Admin";

    private void Logout()
    {
        Session.SignOut();
        Navigation.NavigateTo("/login");
    }
}

