<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeThongThuyetMinhDuLich.Mobile.AuthPage"
             Title="">
    <ScrollView>
        <VerticalStackLayout Padding="18,18,18,24" Spacing="14">
            <Border Background="#1F4B8E"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Padding="16,14">
                <VerticalStackLayout Spacing="6">
                          <Label x:Name="AuthHeroTitleLabel"
                              Text=""
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="24" />
                          <Label x:Name="SessionStatusLabel"
                              Text=""
                           TextColor="#D9E9FF"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button x:Name="LoginTabButton"
                        Grid.Column="0"
                        Text=""
                        Clicked="OnShowLoginClicked"
                        CornerRadius="12"
                        Padding="12,10"
                        BackgroundColor="#2E5BCA"
                        TextColor="White"
                        LineBreakMode="WordWrap" />
                <Button x:Name="RegisterTabButton"
                        Grid.Column="1"
                        Text=""
                        Clicked="OnShowRegisterClicked"
                        CornerRadius="12"
                        Padding="12,10"
                        BackgroundColor="#E8EEF7"
                        TextColor="#1F3555"
                        LineBreakMode="WordWrap" />
            </Grid>

            <Label x:Name="StatusLabel"
                   IsVisible="False"
                   FontSize="13"
                   TextColor="#B42318" />

            <Border x:Name="LoginCard"
                    Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                          <Label x:Name="LoginSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="16"
                           LineBreakMode="WordWrap"
                           TextColor="#23395B" />
                    <Entry x:Name="LoginUsernameEntry" Placeholder="" />
                    <Entry x:Name="LoginPasswordEntry" Placeholder="" IsPassword="True" />
                        <Button x:Name="LoginButton"
                            Text=""
                            Clicked="OnLoginClicked"
                            BackgroundColor="#0E7A6A"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="12,10"
                            LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="RegisterCard"
                    IsVisible="False"
                    Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                          <Label x:Name="RegisterSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="16"
                           LineBreakMode="WordWrap"
                           TextColor="#23395B" />
                        <Entry x:Name="RegisterUsernameEntry" Placeholder="" />
                        <Entry x:Name="RegisterPasswordEntry" Placeholder="" IsPassword="True" />
                        <Entry x:Name="RegisterFullNameEntry" Placeholder="" />
                        <Entry x:Name="RegisterEmailEntry" Placeholder="" Keyboard="Email" />
                        <Entry x:Name="RegisterPhoneEntry" Placeholder="" Keyboard="Telephone" />
                    <Picker x:Name="RegisterLanguagePicker"
                            Title=""
                            ItemDisplayBinding="{Binding TenNgonNgu}" />
                        <Button x:Name="RegisterButton"
                            Text=""
                            Clicked="OnRegisterClicked"
                            BackgroundColor="#2E5BCA"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="12,10"
                            LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

                <Button x:Name="LogoutButton"
                    Text=""
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FDECEC"
                    TextColor="#B42318"
                    CornerRadius="12"
                    Padding="12,10"
                    LineBreakMode="WordWrap"
                    IsVisible="False" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
