<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeThongThuyetMinhDuLich.Mobile.SettingsPage"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- HEADER -->
            <Label Text="⚙️ Cai dat API"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1F3555"/>

            <Label Text="Nhap dia chi server de ket noi"
                   FontSize="14"
                   TextColor="#6B7A90"/>

            <!-- CARD -->
            <Frame CornerRadius="16"
                   Padding="16"
                   BackgroundColor="White"
                   HasShadow="True">

                <VerticalStackLayout Spacing="12">

                    <Label Text="API URL"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <Entry x:Name="ApiEntry"
                           Placeholder="http://172.20.10.2:5000"
                           Keyboard="Url"
                           BackgroundColor="#F1F4F9"
                           HeightRequest="50"
                           Margin="0,5,0,0"/>

                    <!-- BUTTON TEST -->
                    <Button Text="🔍 Test ket noi"
                            Clicked="OnTestClicked"
                            BackgroundColor="#E8EEF7"
                            TextColor="#2E5BCA"
                            CornerRadius="12"/>

                    <!-- BUTTON SAVE -->
                    <Button Text="💾 Luu"
                            Clicked="OnSaveClicked"
                            BackgroundColor="#2E5BCA"
                            TextColor="White"
                            CornerRadius="12"/>

                </VerticalStackLayout>
            </Frame>

            <!-- STATUS -->
            <Label x:Name="StatusLabel"
                   FontSize="14"
                   TextColor="Green"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
