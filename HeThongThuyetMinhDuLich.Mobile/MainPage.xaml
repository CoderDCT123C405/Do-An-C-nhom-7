<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeThongThuyetMinhDuLich.Mobile.MainPage"
             Title="">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4FBFF" Offset="0.0" />
            <GradientStop Color="#ECF5FF" Offset="0.45" />
            <GradientStop Color="#F8F7FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="18,14,18,22" Spacing="14">
            <Border Background="#1F4B8E"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Padding="16,14">
                <VerticalStackLayout Spacing="6">
                      <Label x:Name="HeroTitleLabel"
                          Text=""
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="26" />
                      <Label x:Name="HeroSubtitleLabel"
                          Text=""
                           TextColor="#D9E9FF"
                           FontFamily="OpenSansRegular"
                           FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button x:Name="ReloadButton"
                            Grid.Row="0"
                            Grid.Column="0"
                            Text=""
                            BackgroundColor="#0E7A6A"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="12,10"
                            FontFamily="OpenSansSemibold"
                            LineBreakMode="WordWrap"
                            Clicked="OnReloadClicked" />
                        <ActivityIndicator Grid.Row="0"
                                       Grid.Column="1"
                                       x:Name="LoadingIndicator"
                                       Color="#2E5BCA"
                                       IsRunning="False"
                                       IsVisible="False"
                                       VerticalOptions="Center" />
                        <Button x:Name="RefreshGpsButton"
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Text=""
                            BackgroundColor="#2E5BCA"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="12,10"
                            FontFamily="OpenSansSemibold"
                            LineBreakMode="WordWrap"
                            Clicked="OnRefreshGpsClicked" />
                </Grid>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12"
                    Shadow="0,3,10,#11000000">
                <VerticalStackLayout Spacing="6">
                          <Label x:Name="LocationStatusTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                          <Label x:Name="GpsStatusLabel"
                              Text=""
                           FontSize="12"
                           FontFamily="OpenSansRegular"
                           TextColor="#406080" />
                          <Label x:Name="NearestPoiLabel"
                              Text=""
                           FontSize="13"
                           FontFamily="OpenSansSemibold"
                           TextColor="#224870" />
                    <Label x:Name="GpsTestSectionTitleLabel"
                           Text=""
                           Margin="0,8,0,0"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="#23395B" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button x:Name="StartGpsRouteTestButton"
                                Grid.Column="0"
                                Text=""
                                BackgroundColor="#A44C9C"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="10,8"
                                FontFamily="OpenSansSemibold"
                                LineBreakMode="WordWrap"
                                Clicked="OnStartGpsRouteTestClicked" />
                        <Button x:Name="StartPoiSweepTestButton"
                                Grid.Column="1"
                                Text=""
                                BackgroundColor="#0E7A6A"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="10,8"
                                FontFamily="OpenSansSemibold"
                                LineBreakMode="WordWrap"
                                Clicked="OnStartPoiSweepTestClicked" />
                        <Button x:Name="StopGpsTestButton"
                                Grid.Column="2"
                                Text=""
                                BackgroundColor="#8B2635"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="10,8"
                                FontFamily="OpenSansSemibold"
                                LineBreakMode="WordWrap"
                                Clicked="OnStopGpsTestClicked" />
                    </Grid>
                    <Label x:Name="GpsTestStatusLabel"
                           Text=""
                           FontSize="11"
                           FontFamily="OpenSansRegular"
                           LineBreakMode="WordWrap"
                           TextColor="#4D6B8A" />
                          <Label x:Name="GpsTestProgressTitleLabel"
                              Text=""
                              FontSize="12"
                              FontFamily="OpenSansSemibold"
                              TextColor="#23395B" />
                          <ProgressBar x:Name="GpsTestProgressBar"
                                 Progress="0"
                                 ProgressColor="#0E7A6A"
                                 BackgroundColor="#D8E6F7"
                                 HeightRequest="10" />
                          <Label x:Name="GpsTestProgressLabel"
                              Text=""
                              FontSize="11"
                              FontFamily="OpenSansRegular"
                              LineBreakMode="WordWrap"
                              TextColor="#4D6B8A" />
                          <Label x:Name="GpsTestLogTitleLabel"
                              Text=""
                              FontSize="12"
                              FontFamily="OpenSansSemibold"
                              TextColor="#23395B" />
                          <CollectionView x:Name="GpsTestLogCollection"
                                 HeightRequest="140"
                                 SelectionMode="None">
                           <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}"
                                    FontSize="11"
                                    FontFamily="OpenSansRegular"
                                    LineBreakMode="WordWrap"
                                    Margin="0,0,0,6"
                                    TextColor="#406080" />
                            </DataTemplate>
                           </CollectionView.ItemTemplate>
                          </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="8">
                <Grid x:Name="MapHost"
                      HeightRequest="250" />
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <VerticalStackLayout Spacing="8">
                          <Label x:Name="LanguageSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="DisplayLanguageTitleLabel"
                                Text=""
                                   FontSize="12"
                                   LineBreakMode="WordWrap"
                                   TextColor="#4D6B8A" />
                                <Picker x:Name="DisplayLanguagePicker"
                                    Title=""
                                    ItemDisplayBinding="{Binding TenNgonNgu}"
                                    SelectedIndexChanged="OnDisplayLanguageChanged" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                          <Label x:Name="LanguageStateLabel"
                              Text=""
                           FontSize="11"
                           LineBreakMode="WordWrap"
                           TextColor="#4D6B8A" />
                </VerticalStackLayout>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <VerticalStackLayout Spacing="8">
                          <Label x:Name="QrSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                           <Entry x:Name="QrEntry"
                               Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Placeholder=""
                               ClearButtonVisibility="WhileEditing"
                               BackgroundColor="#F6FAFF"
                               ReturnType="Go" />
                        <Button x:Name="OpenQrButton"
                            Grid.Row="1"
                            Grid.Column="0"
                                Text=""
                                BackgroundColor="#A44C9C"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="12,10"
                                FontFamily="OpenSansSemibold"
                                LineBreakMode="WordWrap"
                                Clicked="OnLookupQrClicked" />
                        <Button x:Name="ScanQrButton"
                            Grid.Row="1"
                            Grid.Column="1"
                                Text=""
                                BackgroundColor="#2E5BCA"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="12,10"
                                FontFamily="OpenSansSemibold"
                                LineBreakMode="WordWrap"
                                Clicked="OnScanQrClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <VerticalStackLayout Spacing="8">
                          <Label x:Name="PoiSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                    <CollectionView x:Name="PoiCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPoiSelectionChanged"
                                    HeightRequest="230">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Stroke="#E3ECF9"
                                        Background="#F9FCFF"
                                        StrokeShape="RoundRectangle 12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding TenDiem}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                               TextColor="#1F3552" />
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding MaDinhDanh}"
                                               FontSize="11"
                                                 HorizontalTextAlignment="End"
                                                 LineBreakMode="TailTruncation"
                                               TextColor="#4D6B8A" />
                                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding DiaChi}"
                                               FontSize="12"
                                                 LineBreakMode="WordWrap"
                                               TextColor="#5F7895" />
                                        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding CoordinateText}"
                                               FontSize="11"
                                                 LineBreakMode="WordWrap"
                                               TextColor="#6A7F96" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Background="#15385F"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,10">
                <VerticalStackLayout Spacing="6">
                      <Label x:Name="SelectedPoiLabel"
                          Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           LineBreakMode="WordWrap"
                           TextColor="#E5F0FF" />
                      <Label x:Name="FallbackLanguageLabel"
                          Text=""
                           IsVisible="False"
                           FontFamily="OpenSansRegular"
                           FontSize="11"
                           LineBreakMode="WordWrap"
                           TextColor="#D9E9FF" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="AudioPlayerCard"
                    Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12"
                    IsVisible="False">
                <VerticalStackLayout Spacing="6">
                          <Label x:Name="AudioPlayerTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                    <WebView x:Name="AudioWebView"
                             HeightRequest="120" />
                </VerticalStackLayout>
            </Border>

            <Border Background="#FFFFFF"
                    Stroke="#D8E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <VerticalStackLayout Spacing="8">
                          <Label x:Name="ContentSectionTitleLabel"
                              Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="#23395B" />
                    <CollectionView x:Name="ContentCollection" HeightRequest="270">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        Stroke="#E3ECF9"
                                        Background="#FCFDFF"
                                        StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding TieuDe}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                                 LineBreakMode="WordWrap"
                                               TextColor="#1F3552" />
                                             <Label Text="{Binding LocalizedLanguageText}"
                                               FontSize="11"
                                                 LineBreakMode="WordWrap"
                                               TextColor="#4D6B8A" />
                                        <Label Text="{Binding NoiDungVanBan}"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="3"
                                               TextColor="#4D6179" />
                                        <Button Text="{Binding LocalizedPlayButtonText}"
                                            BackgroundColor="#156D8A"
                                            TextColor="White"
                                            FontSize="12"
                                            CornerRadius="10"
                                              Padding="12,10"
                                              LineBreakMode="WordWrap"
                                            FontFamily="OpenSansSemibold"
                                                Clicked="OnPlayContentClicked" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
